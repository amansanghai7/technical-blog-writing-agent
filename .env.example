# Copy this file to .env and fill in your values

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Tavily Search — https://tavily.com
TAVILY_API_KEY=tvly-...

# Google (Gemini image generation) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# Supabase PostgreSQL (LangGraph checkpointing) — Settings → Database → Connection String → Session pooler
DATABASE_URI=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Allow LangGraph to deserialize custom Pydantic types from checkpoints
LANGGRAPH_ALLOWED_MSGPACK_MODULES=bwa_backend

# LangSmith tracing (optional) — https://smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=Blog_Writing_Agent

# Output directory for generated blogs and images
# Locally: leave blank (defaults to current directory)
# On EC2: set to /home/ubuntu/blogs
# BLOGS_DIR=/home/ubuntu/blogs
